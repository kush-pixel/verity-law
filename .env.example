# ── CourtListener ───────────────────────────────────────
COURTLISTENER_TOKEN=

# ── Neo4j AuraDB Free ───────────────────────────────────
NEO4J_URI=neo4j+s://xxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# ── Qdrant Cloud Free ───────────────────────────────────
QDRANT_URL=https://xxxx.us-east4-0.gcp.cloud.qdrant.io
QDRANT_API_KEY=

# ── Gemini (Google AI Studio) ───────────────────────────
GEMINI_API_KEY=

# ── LangSmith ───────────────────────────────────────────
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=legal-graphrag

# ── GitHub PAT (for MCP server) ─────────────────────────
GITHUB_PAT=

# ── Deployment URLs ─────────────────────────────────────
RENDER_API_URL=https://your-app.onrender.com
VERCEL_URL=https://your-app.vercel.app